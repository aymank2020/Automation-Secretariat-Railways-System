# ============================================================================
# Production environment for docker-compose.prod.yml
# Copy to ".env" on the server and fill in real values. Never commit .env.
# ============================================================================

# ---- PostgreSQL ---------------------------------------------------------
POSTGRES_USER=railways_user
POSTGRES_PASSWORD=__SET_A_LONG_RANDOM_STRING__
POSTGRES_DB=railways_hr

# ---- Backend ------------------------------------------------------------
# Generate with: openssl rand -hex 64
SECRET_KEY=__GENERATE_WITH_openssl_rand_hex_64__
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed origins for CORS. For Cloudflare Tunnel
# private hostnames, set this to the hostname your users will hit, e.g.
#   ALLOW_ORIGINS=http://railways-secretariat
# For a public domain:
#   ALLOW_ORIGINS=https://your-domain.example.com
ALLOW_ORIGINS=http://railways-secretariat

# ---- Initial admin (used only on first startup against an empty DB) ----
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=__SET_A_STRONG_INITIAL_ADMIN_PASSWORD__

# ---- Cloudflare Tunnel --------------------------------------------------
# Tunnel token from Cloudflare Zero Trust dashboard ->
# Networks -> Tunnels -> your tunnel -> install command (after `--token`).
CLOUDFLARE_TUNNEL_TOKEN=__PASTE_YOUR_TUNNEL_TOKEN_HERE__

# ---- Logging -----------------------------------------------------------
LOG_LEVEL=INFO
