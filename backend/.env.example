# --- Database ---
# Local dev (SQLite, no server required)
DATABASE_URL=sqlite:///./railways_hr.db
# Production (PostgreSQL):
# DATABASE_URL=postgresql+psycopg://railways_user:CHANGE_ME@postgres:5432/railways_hr

# --- JWT ---
# Generate a strong key with: openssl rand -hex 64
SECRET_KEY=please-generate-with-openssl-rand-hex-64-and-replace-this-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- CORS ---
# Comma-separated list of allowed origins for the SPA. Use the production
# URL in production. For local dev keep the Vite default.
ALLOW_ORIGINS=http://localhost:5173

# --- Initial admin (used only on first startup against an empty DB) ---
INITIAL_ADMIN_USERNAME=admin
# Pick a strong password. If left blank the app will NOT create any user
# and you must add one via the API or seed_db.py later.
INITIAL_ADMIN_PASSWORD=

# --- Uploads ---
UPLOAD_DIR=./uploads
